{
  "$schema": "https://opencode.ai/config.json",

  // Disable session sharing
  "share": "disabled",

  // Disable auto-update (image is immutable, update by rebuilding)
  "autoupdate": false,

  // Disable all built-in LSP servers
  "lsp": false,

  "experimental": {
    // Disable OpenTelemetry export
    "openTelemetry": false
  },

  // Add your own providers here, or configure API keys directly in the web UI.
  // See https://opencode.ai/docs/providers
  "provider": {}
}
